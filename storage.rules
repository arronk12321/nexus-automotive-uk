rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── Helper: admin check ──
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'kostileka@gmail.com';
    }

    // ── ECU uploads: users upload to their own folder ──
    match /ecu-uploads/{userId}/{allPaths=**} {
      allow read:   if request.auth != null
                    && (request.auth.uid == userId || isAdmin());
      allow write:  if request.auth != null && request.auth.uid == userId;
    }

    // ── Modified files: admin uploads, owner + admin reads ──
    match /modified/{allPaths=**} {
      allow read:   if request.auth != null;
      allow write:  if isAdmin();
    }

    // ── Default: deny ──
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
